{
  "name": "nuxt-app",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit",
    "e2e": "playwright test"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,vue}": "eslint --fix",
    "*.{css,md,json,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@floating-ui/vue": "^1.1.11",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/scripts": "^0.11.0",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/supabase": "^1.5.0",
    "@nuxtjs/tailwindcss": "^6.7.0",
    "@nuxtjs/turnstile": "^0.9.12",
    "@playwright/test": "^1.59.1",
    "@tanstack/vue-query": "^5.100.9",
    "@types/node": "^20.19.40",
    "@unhead/vue": "^2.0.3",
    "@vee-validate/zod": "^4.15.1",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nuxt": "^3.21.5",
    "prettier": "^2.8.8",
    "prettier-plugin-tailwindcss": "^0.2.8",
    "typescript": "~5.6.3",
    "vee-validate": "^4.15.1",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.2.8",
    "zod": "^3.23.8"
  },
  "overrides": {
    "vue": "latest"
  },
  "dependencies": {
    "@nuxt/kit": "^3.15.4",
    "@pinia/nuxt": "^0.5.5",
    "pinia": "^2.0.35"
  }
}
